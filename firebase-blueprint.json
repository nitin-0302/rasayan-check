{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about a registered user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "college": { "type": "string" },
        "isAdmin": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "email"]
    },
    "Registration": {
      "title": "Event Registration",
      "description": "User participation record for events",
      "type": "object",
      "properties": {
        "registrationId": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "userName": { "type": "string" },
        "eventIds": { "type": "array", "items": { "type": "string" } },
        "confirmationMessage": { "type": "string" },
        "registrationTime": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "eventIds", "registrationTime"]
    },
    "ChatMessage": {
      "title": "Community Message",
      "description": "Message in the global community chat",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "text", "timestamp"]
    },
    "Announcement": {
      "title": "Fest Announcement",
      "description": "Official announcement from fest admins",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "author": { "type": "string" }
      },
      "required": ["title", "content", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    },
    "/registrations/{registrationId}": {
      "schema": "Registration",
      "description": "Registration records for events"
    },
    "/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Community chat messages"
    },
    "/announcements/{announcementId}": {
      "schema": "Announcement",
      "description": "Official fest announcements"
    }
  }
}
